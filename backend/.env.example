# DevCast environment variables.
# Copy this file to backend/.env and fill in real values; .env is gitignored.
# In production these are set on the ECS Express Mode service config instead.
# See docs/adr/009-secrets-and-aws-credentials.md.

# OpenAI API key — used server-side for content-extraction cleaning (ADR 005)
# and two-host script generation (ADR 003). Get one at:
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# S3 bucket name where each episode is stored as `episodes/{ulid}.mp3` (audio)
# and `episodes/{ulid}.json` (metadata sidecar). The bucket policy and
# lifecycle rule the app expects are documented in ADR 008.
DEVCAST_S3_BUCKET=

# AWS region the bucket lives in. Also used to construct public S3 URLs.
AWS_REGION=us-east-1

# AWS profile (LOCAL DEV ONLY). boto3 picks creds up from ~/.aws/credentials.
# In production this is unset — the ECS task role provides credentials via
# the task metadata endpoint. See ADR 009.
AWS_PROFILE=devcast-dev
